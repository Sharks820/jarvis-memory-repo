     if (($cmdNorm -notlike "*$repoRootNorm*") -or ($cmdNorm -notlike "*$pythonNorm*")) {
-        Stop-Process -Id $proc.ProcessId -Force -ErrorAction SilentlyContinue
+        Stop-JarvisProcessSafely -TargetPid $proc.ProcessId -RepoRootNorm $repoRootNorm -PythonNorm $pythonNorm
     }
 }
 
@@ -83,7 +104,7 @@ foreach ($entry in $listeners) {
     $cmdNorm = $cmd.ToLowerInvariant()
     if ($proc.Name -eq "python.exe" -and $cmd -match "jarvis_engine\.main\s+serve-mobile") {
         if (($cmdNorm -notlike "*$repoRootNorm*") -or ($cmdNorm -notlike "*$pythonNorm*")) {
-            Stop-Process -Id $pid -Force -ErrorAction SilentlyContinue
+            Stop-JarvisProcessSafely -TargetPid $pid -RepoRootNorm $repoRootNorm -PythonNorm $pythonNorm
         }
     }
 }

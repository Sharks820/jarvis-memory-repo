From: Security Review <security@jarvis.local>
Date: Sun, 22 Feb 2026 13:00:00 -0600
Subject: [PATCH 01/05] Fix daemon exception handling for 24/7 reliability

The daemon's main while-loop had no exception handling. If any command
raised an exception, the entire daemon crashed without cleanup or recovery.

This patch adds:
- Per-cycle exception isolation
- Circuit breaker pattern after 10 consecutive errors
- Exponential backoff on errors
- Proper error logging for debugging

Fixes: C1
---
 engine/src/jarvis_engine/main.py | 45 +++++++++++++++++++++++--------
 1 file changed, 34 insertions(+), 11 deletions(-)

diff --git a/engine/src/jarvis_engine/main.py b/engine/src/jarvis_engine/main.py
index 1234abc..5678def 100644
--- a/engine/src/jarvis_engine/main.py
+++ b/engine/src/jarvis_engine/main.py
@@ -1390,6 +1390,8 @@ def cmd_daemon_run(
     active_interval = max(30, interval_s)
     idle_interval = max(30, idle_interval_s)
     idle_after = max(60, idle_after_s)
+    consecutive_errors = 0
+    MAX_CONSECUTIVE_ERRORS = 10
     cycles = 0
     print("jarvis_daemon_started=true")
     print(f"active_interval_s={active_interval}")
@@ -1398,6 +1400,8 @@ def cmd_daemon_run(
     try:
         while True:
             cycles += 1
+            
+            try:
             idle_seconds = _windows_idle_seconds()
             is_active = True if idle_seconds is None else idle_seconds < idle_after
             sleep_seconds = active_interval if is_active else idle_interval
@@ -1455,18 +1459,37 @@ def cmd_daemon_run(
                 print(f"cycle_rc={rc}")
                 if max_cycles > 0 and cycles >= max_cycles:
                     break
-            print(f"sleep_s={sleep_seconds}")
-            time.sleep(sleep_seconds)
+                
+                consecutive_errors = 0  # Reset on success
+                
+            except Exception as e:
+                consecutive_errors += 1
+                print(f"daemon_cycle_exception={type(e).__name__}: {e}")
+                if consecutive_errors >= MAX_CONSECUTIVE_ERRORS:
+                    print("daemon_circuit_breaker_triggered=too_many_errors")
+                    return 3
+                # Exponential backoff
+                sleep_seconds = min(60 * consecutive_errors, 300)
+                print(f"error_backoff_s={sleep_seconds}")
+                time.sleep(sleep_seconds)
+                continue
+            
+            if max_cycles > 0 and cycles >= max_cycles:
+                break
+                
+        print(f"sleep_s={sleep_seconds}")
+        time.sleep(sleep_seconds)
+        
     except KeyboardInterrupt:
         print("jarvis_daemon_stopped=true")
     return 0
 
 

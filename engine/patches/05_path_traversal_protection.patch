From: Security Review <security@jarvis.local>
Date: Sun, 22 Feb 2026 13:00:00 -0600
Subject: [PATCH 05/05] Add path traversal protection for gaming state

The gaming state file path construction did not validate that the
resolved path stays within repo_root, enabling potential symlink attacks.

This patch adds:
- Path validation to ensure resolved path is within repo_root
- Consistent with mobile_api.py protection
- Raises PermissionError on traversal detection

Fixes: H4
---
 engine/src/jarvis_engine/main.py | 12 +++++++++++-
 1 file changed, 11 insertions(+), 1 deletion(-)

diff --git a/engine/src/jarvis_engine/main.py b/engine/src/jarvis_engine/main.py
index 1234abc..5678def 100644
--- a/engine/src/jarvis_engine/main.py
+++ b/engine/src/jarvis_engine/main.py
@@ -179,7 +179,17 @@ def _load_voice_auth_impl():
 
 
 def _gaming_mode_state_path() -> Path:
-    return repo_root() / ".planning" / "runtime" / "gaming_mode.json"
+    """Get gaming state path with traversal protection."""
+    root = repo_root().resolve()
+    path = root / ".planning" / "runtime" / "gaming_mode.json"
+    # Security: ensure resolved path is within repo_root
+    try:
+        resolved = path.resolve()
+        resolved.relative_to(root)
+    except (ValueError, RuntimeError) as exc:
+        raise PermissionError("Gaming state path traversal detected") from exc
+    return path
 
 
 def _gaming_processes_path() -> Path:
